# App
API_KEY=change-me-to-a-secure-random-string
DEBUG=false
# DEV_AUTH_BYPASS=false   # NEVER set to true in production — bypasses Telegram auth entirely

# LLM — all requests routed through LiteLLM proxy
LLM_API_KEY=anything        # required by the OpenAI client; can be a dummy string if LiteLLM handles auth
LLM_BASE_URL=http://litellm:4000

# Database
DATABASE_URL=postgresql+asyncpg://aug:password@localhost:5432/aug

# Telegram (optional — bot is disabled if not set, uses polling mode)
# TELEGRAM_BOT_TOKEN=

# Brave Search (optional — web search tool is disabled if not set)
# BRAVE_API_KEY=

# Portainer (optional — portainer tools disabled if not set)
# PORTAINER_URL=http://portainer:9000
# PORTAINER_API_TOKEN=
# PORTAINER_ENDPOINT_ID=1


# Gmail OAuth (optional — Gmail tools are disabled if not set)
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=

# Mini App — URL of the AUG backend, as reachable from the browser (used at build time)
# MINIAPP_API_URL=https://api.yourdomain.com

# Base URL of this server — used for OAuth redirect URIs and auth links sent to users.
# Required for Docker/Portainer deployments. Replace YOUR_HOST with your server's IP or domain.
# BASE_URL=http://YOUR_HOST:8012

# Browser UI — protects the Chrome web interface (port 3000) with basic auth
# CHROME_USER=aug       # default: aug
# CHROME_PASSWORD=      # set this — do not leave the UI unprotected
