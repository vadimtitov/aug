# App
API_KEY=change-me-to-a-secure-random-string
DEBUG=false

# LLM — all requests routed through LiteLLM proxy
LLM_API_KEY=anything        # required by the OpenAI client; can be a dummy string if LiteLLM handles auth
LLM_BASE_URL=http://litellm:4000

# Database
DATABASE_URL=postgresql+asyncpg://aug:password@localhost:5432/aug

# Telegram (optional — bot is disabled if not set, uses polling mode)
# TELEGRAM_BOT_TOKEN=

# Brave Search (optional — web search tool is disabled if not set)
# BRAVE_API_KEY=

# Browser UI — protects the Chrome web interface (port 3000) with basic auth
# CHROME_USER=aug       # default: aug
# CHROME_PASSWORD=      # set this — do not leave the UI unprotected
